// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String          @id @default(cuid())
  username                String          @unique @db.VarChar(24)
  passwordHash            String
  bio                     String?         @db.VarChar(500)
  avatarBytes             Bytes?
  avatarMimeType          String?         @db.VarChar(32)
  avatarUpdatedAt         DateTime?
  createdAt               DateTime        @default(now())
  lastNotificationCheckAt DateTime        @default(now())
  sessions                Session[]
  reviews                 Review[]
  comments                ReviewComment[]
  favoriteGames           FavoriteGame[]
  wishlist                WishlistEntry[]
  friends                 Friendship[]    @relation("FriendOwner")
  friendedBy              Friendship[]    @relation("FriendTarget")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Game {
  id           Int             @id
  slug         String
  name         String
  summary      String?         @db.Text
  coverUrl     String?
  releaseDate  DateTime?
  genres       String[]
  platforms    String[]
  igdbRating   Float?
  popularity   Float?
  updatedAt    DateTime        @updatedAt
  reviews      Review[]
  favoritedBy  FavoriteGame[]
  wishlistedBy WishlistEntry[]

  @@index([name])
  @@index([popularity(sort: Desc)])
}

model Review {
  id          String          @id @default(cuid())
  rating      Float
  body        String?         @db.Text
  hoursPlayed Float?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  userId      String
  gameId      Int
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  game        Game            @relation(fields: [gameId], references: [id], onDelete: Cascade)
  comments    ReviewComment[]

  @@unique([userId, gameId])
  @@index([createdAt(sort: Desc)])
  @@index([gameId, createdAt(sort: Desc)])
}

model ReviewComment {
  id        String   @id @default(cuid())
  body      String   @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  reviewId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId, createdAt])
  @@index([userId])
}

model FavoriteGame {
  userId    String
  gameId    Int
  position  Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@id([userId, gameId])
  @@unique([userId, position])
  @@index([gameId])
}

model WishlistEntry {
  userId    String
  gameId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@id([userId, gameId])
  @@index([gameId])
  @@index([userId, createdAt(sort: Desc)])
}

model RateLimitBucket {
  key       String   @id @db.VarChar(64)
  count     Int
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model Friendship {
  userId    String
  friendId  String
  createdAt DateTime @default(now())
  user      User     @relation("FriendOwner", fields: [userId], references: [id], onDelete: Cascade)
  friend    User     @relation("FriendTarget", fields: [friendId], references: [id], onDelete: Cascade)

  @@id([userId, friendId])
  @@index([friendId])
}
